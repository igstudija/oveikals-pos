# MongoDB savienojuma virkne (no MongoDB Atlas)
MONGODB_URI="mongodb+srv://lietotajs:parole@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Datu bāzes nosaukums (nav obligāts, noklusējums: oveikals_pos)
MONGODB_DB="oveikals_pos"

# Admin paneļa pieeja
# Lietotāji (e-pasti), kas drīkst pieslēgties — atdala ar komatu
ADMIN_EMAILS="evelina.abele@orkla.lv,artis@codars.com"
# Sākotnējā parole, ar ko kontus izveido (vēlāk maina caur paroles atjaunošanu)
ADMIN_PASSWORD="izveli-drosu-paroli"

# Publiskais app URL (paroles atjaunošanas saitēm). Ja tukšs, ņem no pieprasījuma.
APP_URL="https://oveikals.lv"

# Email (SMTP) paroles atjaunošanas vēstulēm
SMTP_HOST="in-v3.mailjet.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tavs-mailjet-api-key"
SMTP_PASS="tavs-mailjet-secret-key"
EMAIL_FROM="web@codars.dev"
EMAIL_FROM_NAME="Oveikals POS"

# Slepenā atslēga sīkdatņu parakstīšanai (jebkura gara nejauša virkne)
AUTH_SECRET="kaut-kada-gara-nejausa-virkne-123456"

# Ceļš zem kura dzīvo aplikācija (noklusējums /pos)
NEXT_PUBLIC_BASE_PATH="/pos"

# BunnyCDN Storage (slaidu attēli)
BUNNY_STORAGE_ZONE="oveikals"
BUNNY_STORAGE_HOST="storage.bunnycdn.com"
BUNNY_ACCESS_KEY="tavs-storage-zone-password"
BUNNY_CDN_URL="https://oveikals.b-cdn.net"
