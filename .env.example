# MongoDB savienojuma virkne (no MongoDB Atlas)
MONGODB_URI="mongodb+srv://lietotajs:parole@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Datu bāzes nosaukums (nav obligāts, noklusējums: oveikals_pos)
MONGODB_DB="oveikals_pos"

# Admin paroles (izvēlies pats)
ADMIN_PASSWORD="izveli-drosu-paroli"

# Slepenā atslēga sīkdatņu parakstīšanai (jebkura gara nejauša virkne)
AUTH_SECRET="kaut-kada-gara-nejausa-virkne-123456"

# Ceļš zem kura dzīvo aplikācija (noklusējums /pos)
NEXT_PUBLIC_BASE_PATH="/pos"
